{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "autoMemoryEnabled": false,
  "language": "korean",
  "env": {
    "CLAUDE_AGENT_WORKSPACE_POLICY": ".claude/policies/agent-workspace.json"
  },
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [],
  "disabledMcpjsonServers": [],
  "extraKnownMarketplaces": {
    "claude-code-plugins": {
      "source": { "source": "github", "repo": "anthropics/claude-code" }
    }
  },
  "enabledPlugins": {
    "code-review@claude-code-plugins": true,
    "commit-commands@claude-code-plugins": true,
    "explanatory-output-style@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true
  },
  "permissions": {
    "allow": [],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_agent_workspace.py\" --policy \"$CLAUDE_AGENT_WORKSPACE_POLICY\"",
            "statusMessage": "Checking agent workspace policy",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_word_json.py\"",
            "statusMessage": "Checking terminology dictionary edits",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_word_json.py\"",
            "statusMessage": "Validating terminology dictionary",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/sync_component_contracts.py\"",
            "statusMessage": "Syncing component contract structure",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/update_skill_index.py\"",
            "statusMessage": "Updating skill index",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/update_agent_index.py\"",
            "statusMessage": "Updating agent index",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/task_ledger.py\"",
            "statusMessage": "Recording executed work in the task ledger",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/detect_promotions.py\"",
            "statusMessage": "Evaluating skill/agent promotion conditions",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/detect_promotions.py\"",
            "statusMessage": "Surfacing pending skill/agent promotion candidates",
            "timeout": 30
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "skills",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/update_skill_index.py\"",
            "statusMessage": "Updating skill index",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "skills",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/sync_component_contracts.py\" --force",
            "statusMessage": "Syncing skill/task/subagent contracts",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
