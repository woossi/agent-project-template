{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {}
    },
    "scrapling": {
      "type": "stdio",
      "command": "/Users/ujunbin/.local/share/scrapling-mcp-venv/bin/scrapling",
      "args": [
        "mcp"
      ],
      "env": {}
    },
    "paperbanana": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "paperbanana[mcp]",
        "paperbanana-mcp"
      ]
    }
  }
}