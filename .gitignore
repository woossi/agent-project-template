.DS_Store
**/.DS_Store
__pycache__/
*.pyc

# Python venvs (uv-managed, recreated from requirements.txt)
.venv/
**/.venv/
*.egg-info/
.pytest_cache/

# Rust build output
target/

# Claude Code local (personal) settings — not shared; use settings.json for shared defaults
.claude/settings.local.json

# Conductor workspace-local context
.context/

# Team runtime: inbox messages and per-agent/per-team work context (keep dirs, ignore contents)
.project/inbox/*/
teams/*/.claude/inbox/*.json
teams/*/.claude/inbox/**/*.json
teams/.orchestrator/inbox/*.json
teams/.orchestrator/inbox/**/*.json
teams/*/.claude/inbox/.claimed/
teams/*/.claude/inbox/.consumed/
teams/.orchestrator/inbox/.claimed/
teams/.orchestrator/inbox/.consumed/
agents/*/.context/
teams/*/*/.context/
teams/*/.context/
outputs/

# Team promotion runtime (candidates recomputed; decisions are instance state)
.project/promotions/
.project/derivations/

# Playwright CLI runtime console logs
.playwright-cli/
